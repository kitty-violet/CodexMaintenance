# Codex Maintenance local configuration example
# Copy to CodexMaintenance.config or run:
#   CodexMaintenance.exe --configure

CodexHome=%USERPROFILE%\.codex
# Default behavior: use a backups folder beside CodexMaintenance.config.
# You can change this to another drive, for example: D:\CodexMaintenance\backups
BackupRoot=backups
KeepBackups=5
VacuumThresholdMb=20.0
